# Docker Compose uses the `db` hostname. For manual local setup, replace `db` with `localhost`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/prepiq
# Required for signing and verifying auth tokens. Use a long random value and never commit a real secret.
APP_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_HOURS=168
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_URL=https://github.com/Aashikhandelwal05/prepiq
OPENROUTER_APP_NAME=PrepIQ
OPENROUTER_TIMEOUT_SECONDS=30
# Leave blank for Vite dev-server proxy. Set an explicit URL for Dockerized or deployed frontend builds.
VITE_API_BASE_URL=
